{
  "name": "architect-ai-agape-sovereign-enclave",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev-frontend": "npm run dev --prefix frontend",
    "dev-backend": "tsx watch --env-file=.env.local server.ts",
    "dev": "concurrently \"npm run dev-frontend\" \"npm run dev-backend\"",
    "typecheck": "tsc --noEmit",
    "build": "vite build && esbuild server.ts --bundle --platform=node --target=node20 --outfile=dist/server.js --format=esm --packages=external",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^8.3.1",
    "@google/genai": "latest",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "firebase": "latest",
    "firebase-admin": "^14.1.0",
    "framer-motion": "latest",
    "git": "^0.1.5",
    "google-auth-library": "^10.9.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-is": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "latest",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "latest",
    "remark-gfm": "^4.0.1",
    "sonner": "latest",
    "tailwindcss": "latest",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "esbuild": "latest",
    "tsx": "^4.23.0",
    "typescript": "latest",
    "vite": "latest"
  },
  "allowScripts": {
    "git@0.1.5": true
  }
}
