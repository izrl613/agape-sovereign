{
  "terminal.integrated.defaultProfile.osx": "bash",
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.analysis.extraPaths": [
    "${workspaceFolder}/.venv/lib/python3.9/site-packages"
  ],
  "files.autoSave": "onFocusChange",
  "git.statusLimit": 0,
  "git.suggestSmartCommit": false,
  "go.toolsManagement.autoUpdate": true,
  "npm.packageManager": "npm",
  "npm.scriptRunner": "npm",
  "editor.fontSize": 14,
  "workbench.editor.enablePreview": true,
  "livePreview.start.preview.at.file.open": true,
  "livePreview.autoRefreshPreview": "On Changes",
  "workbench.colorTheme": "Default Dark+",
  "workbench.colorCustomizations": {
    "statusBar.background": "#007acc",
    "statusBar.noFolderBackground": "#007acc",
    "statusBar.debuggingBackground": "#007acc",
    "statusBar.foreground": "#ffffff"
  }
}