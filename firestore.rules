rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Default Deny All
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable global security primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Sovereign user accounts & private sandboxes
    match /users/{userId} {
      allow get, write: if isOwner(userId);

      // Identity Sandbox Partition Modules Subcollection
      match /modules/{moduleId} {
        allow read, write: if isOwner(userId);
      }

      // Symmetrically ciphered password keychains
      match /passwords/{passwordId} {
        allow read, write: if isOwner(userId);
      }

      // E2EE encrypted chats/messages logs
      match /messages/{messageId} {
        allow read, write: if isOwner(userId);
      }

      // Sovereign Secure Document Vault
      match /vault/{vaultId} {
        allow read, write: if isOwner(userId);
      }

      // Intercepted trackers metrics log
      match /trackers/{trackerId} {
        allow read, write: if isOwner(userId);
      }

      // Dynamic Security Audit Logs
      match /auditLogs/{logId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
