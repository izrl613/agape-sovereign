# ── Agape Sovereign Enclave — Environment Variables ──────────────────────────

# Firebase (Client-side — prefix with VITE_ for Vite)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Cloud (Server-side)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=

# WebAuthn / Passkey Configuration
# ─────────────────────────────────────────────────────────────────────────────
# WEBAUTHN_RP_ID must match the domain the PWA is served from.
# - Local dev:    localhost
# - Production:   sovereign.nyc  (NO https://, NO port, NO path)
#
# WEBAUTHN_ORIGIN must be the full origin (scheme + host + optional port):
# - Local dev:    http://localhost:5000
# - Production:   https://sovereign.nyc
#
# To force hardware-key-only (YubiKey, etc.) set WEBAUTHN_RP_ID + WEBAUTHN_ORIGIN
# and ensure generateRegistrationOptions uses authenticatorAttachment: 'cross-platform'
# ─────────────────────────────────────────────────────────────────────────────
WEBAUTHN_RP_NAME=Agape Sovereign
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5000

# Server
PORT=5000
PROXY_HEADER=
