{
  "name": "local-llm-pwa-backend",
  "version": "1.0.0",
  "description": "Local LLM backend using Genkit + Ollama - zero cloud dependencies",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "genkit:dev": "genkit start -- tsx watch src/server.ts",
    "genkit:build": "genkit build",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "genkitx-ollama": "^1.40.0",
    "genkit": "^1.40.0",
    "@genkit-ai/core": "^1.40.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "ws": "^8.16.0",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0"
  }
}