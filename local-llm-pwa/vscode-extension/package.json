{
  "name": "local-llm-pwa-vscode",
  "displayName": "Local LLM PWA",
  "description": "VS Code extension for Local LLM PWA - manage models, chat, and backend from VS Code",
  "version": "1.0.0",
  "publisher": "local-llm-pwa",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Machine Learning", "Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "local-llm-pwa.startBackend",
        "title": "Start Local LLM Backend",
        "category": "Local LLM"
      },
      {
        "command": "local-llm-pwa.stopBackend",
        "title": "Stop Local LLM Backend",
        "category": "Local LLM"
      },
      {
        "command": "local-llm-pwa.openChat",
        "title": "Open Chat Panel",
        "category": "Local LLM"
      },
      {
        "command": "local-llm-pwa.openModels",
        "title": "Open Model Manager",
        "category": "Local LLM"
      },
      {
        "command": "local-llm-pwa.pullModel",
        "title": "Pull Model",
        "category": "Local LLM"
      },
      {
        "command": "local-llm-pwa.deleteModel",
        "title": "Delete Model",
        "category": "Local LLM"
      },
      {
        "command": "local-llm-pwa.refreshModels",
        "title": "Refresh Models",
        "category": "Local LLM"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "local-llm-pwa",
          "title": "Local LLM",
          "icon": "media/llm-icon.svg"
        }
      ]
    },
    "views": {
      "local-llm-pwa": [
        {
          "id": "local-llm-pwa.chat",
          "name": "Chat"
        },
        {
          "id": "local-llm-pwa.models",
          "name": "Models"
        },
        {
          "id": "local-llm-pwa.backend",
          "name": "Backend"
        }
      ]
    },
    "configuration": {
      "title": "Local LLM PWA",
      "properties": {
        "local-llm-pwa.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server URL"
        },
        "local-llm-pwa.backendPort": {
          "type": "number",
          "default": 3000,
          "description": "Backend server port"
        },
        "local-llm-pwa.autoStartBackend": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start backend on VS Code startup"
        },
        "local-llm-pwa.defaultModel": {
          "type": "string",
          "default": "llama3.2:3b",
          "description": "Default model for chat"
        }
      }
    },
    "keybindings": [
      {
        "command": "local-llm-pwa.openChat",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l",
        "when": "editorTextFocus"
      },
      {
        "command": "local-llm-pwa.startBackend",
        "key": "ctrl+alt+b",
        "mac": "cmd+alt+b"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "local-llm-pwa.refreshModels",
          "when": "view == local-llm-pwa.models",
          "group": "navigation"
        },
        {
          "command": "local-llm-pwa.pullModel",
          "when": "view == local-llm-pwa.models",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "local-llm-pwa.openChat",
          "when": "editorFocus",
          "group": "local-llm-pwa"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0"
  }
}