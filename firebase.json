{
  "hosting": {
    "public": "dist",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/privacy",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      },
      {
        "source": "/terms",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/auth/**",
        "run": {
          "serviceId": "authapi",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/mcp/**",
        "run": {
          "serviceId": "architect-ai",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/**",
        "run": {
          "serviceId": "agape-sovereign-server",
          "region": "us-central1"
        }
      },
      {
        "source": "/api-proxy",
        "run": {
          "serviceId": "agape-sovereign-server",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "database": "agape-sovereign",
    "location": "nam7",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules",
    "bucket": "agape-sovereign.firebasestorage.app"
  },
  "database": {
    "rules": "database.rules.json"
  },
  "functions": [
    {
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ],
      "disallowLegacyRuntimeConfig": true,
      "source": "functions"
    }
  ],
  "apphosting": [
    {
      "backendId": "agape-sovereign",
      "rootDir": "/",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "functions",
        "gemma-chat-public",
        "google-cloud-sdk",
        "architect-ai",
        "architectai",
        "frontend",
        "backend",
        "dist",
        "public",
        "docs",
        ".github",
        ".vscode",
        ".agents",
        ".firebase",
        "scripts",
        "dataconnect",
        ".DS_Store",
        "*.mp4",
        "*.zip",
        "*.tar",
        "*.tar.gz"
      ],
      "alwaysDeployFromSource": true
    }
  ],
  "dataconnect": {
    "source": "dataconnect"
  },
  "remoteconfig": {
    "template": "remoteconfig.template.json"
  },
  "extensions": {},
  "auth": {
    "providers": {
      "anonymous": true,
      "emailPassword": true,
      "googleSignIn": {
        "oAuthBrandDisplayName": "Agape Sovereign | Architect AI",
        "supportEmail": "agape@sovereign.nyc"
      }
    }
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "hosting": {
      "port": 5000
    },
    "storage": {
      "port": 9199
    },
    "database": {
      "port": 9000
    },
    "pubsub": {
      "port": 8085
    },
    "eventarc": {
      "port": 9299
    },
    "tasks": {
      "port": 9499
    },
    "dataconnect": {
      "dataDir": "dataconnect/.dataconnect/pgliteData",
      "port": 9399
    },
    "apphosting": {
      "port": 5002,
      "rootDirectory": "./",
      "startCommand": "npm run dev"
    },
    "ui": {
      "enabled": true
    },
    "singleProjectMode": true
  }
}
